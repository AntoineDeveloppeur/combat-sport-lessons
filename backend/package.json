{
  "name": "combat-sport-lesson",
  "version": "1.0.0",
  "description": "Voir et créer des lessons de sport de combat",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "test": "vitest --watch --config config/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config config/vitest.config.ts",
    "start": "node ./dist/presentation/server.js",
    "dev": "nodemon ./dist/presentation/server.js",
    "type:watch": "npx tsc --watch --project config/tsconfig.json",
    "build": "npx tsc --project config/tsconfig.json",
    "lint": "npx eslint --config config/eslint.config.ts",
    "prettier": "npx prettier . --write",
    "db:start": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file ../.env up postgres postgres_test",
    "db:stop": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file ../.env down",
    "db:reset": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file ../.env down -v && npm run db:start",
    "db:start:tools": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file ../.env --profile tools up -d",
    "db:prod:start": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file ../.env up -d",
    "db:prod:stop": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file ../.env down",
    "db:prod:logs": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file ../.env logs -f postgres"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.11",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.2",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "prettier": "3.7.4",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.18"
  }
}
