# Environment
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:3000


# API
API_PROTOCOL=http
API_HOST=localhost
API_PORT=4000


# Database (production/dev)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=combat_lesson_db

# Database (test)
POSTGRES_TEST_HOST=localhost
POSTGRES_TEST_PORT=5433
POSTGRES_TEST_USER=user
POSTGRES_TEST_PASSWORD=your_test_password_here
POSTGRES_TEST_DB=test

# PgAdmin (optional - only needed if using npm run db:start:tools)
PGADMIN_PORT=8888
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password_here

# JWT Secret (IMPORTANT: Generate a secure random string for production)
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# Google reCAPTCHA v3
# Get your keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Test keys (for development - these always pass)
# RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
# RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
