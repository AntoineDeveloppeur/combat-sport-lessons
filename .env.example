# ================================================================================
# COMBAT SPORT LESSONS - ENVIRONMENT CONFIGURATION
# ================================================================================
# 
# IMPORTANT: This file must be placed at the ROOT of the project
# Do NOT create .env files in backend/ or frontend/ subdirectories
#
# Quick Setup:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and configure at minimum:
#    - JWT_SECRET (generate a secure random string)
#    - POSTGRES_PASSWORD (choose a secure password)
#    - POSTGRES_TEST_PASSWORD (choose a secure password)
# 3. For production, also configure reCAPTCHA keys
#
# ================================================================================

# ================================================================================
# ENVIRONMENT
# ================================================================================
# Options: development | production | test
NODE_ENV=development

# ================================================================================
# FRONTEND CONFIGURATION
# ================================================================================
FRONTEND_URL=http://localhost:3000

# Google reCAPTCHA v3 (Frontend)
# For local development, you can use the test keys below (they always pass)
# For production, get your keys from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI

# ================================================================================
# BACKEND API CONFIGURATION
# ================================================================================
# API
API_PORT=4010

#local
API_URL=http://localhost:4010

# ================================================================================
# JWT AUTHENTICATION
# ================================================================================
# CRITICAL: Generate a secure random string (minimum 32 characters)
# Example generation methods:
#   - Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   - OpenSSL: openssl rand -hex 32
#   - Online: https://www.grc.com/passwords.htm
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_CHANGE_THIS

# ================================================================================
# GOOGLE RECAPTCHA v3 (Backend)
# ================================================================================
# For local development, use these test keys (they always pass validation)
# For production, get your keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# Production keys (uncomment and configure for production):
# RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# ================================================================================
# DATABASE - DEVELOPMENT/PRODUCTION
# ================================================================================
# PostgreSQL instance for development and production
# Runs on port 5432 via Docker (npm run db:start)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here_CHANGE_THIS
POSTGRES_DB=combat_lesson_db

# ================================================================================
# DATABASE - TEST
# ================================================================================
# Separate PostgreSQL instance for tests
# Runs on port 5433 via Docker (automatically started with npm run db:start)
POSTGRES_TEST_HOST=localhost
POSTGRES_TEST_PORT=5433
POSTGRES_TEST_USER=user
POSTGRES_TEST_PASSWORD=your_test_password_here_CHANGE_THIS
POSTGRES_TEST_DB=test

# ================================================================================
# PGADMIN (OPTIONAL)
# ================================================================================
# PgAdmin is a web-based PostgreSQL administration tool
# Only starts if you run: npm run db:start:tools (instead of npm run db:start)
# Access at: http://localhost:8888
PGADMIN_PORT=8888
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password_here_CHANGE_THIS

# ================================================================================
# NOTES
# ================================================================================
# - All passwords should be changed from defaults before deployment
# - For production, use strong passwords (16+ characters, mixed case, numbers, symbols)
# - Never commit the .env file to version control (it's in .gitignore)
# - Keep .env.example updated when adding new environment variables
# ================================================================================
