{
  "name": "combat-sport-lessons-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "scripts": {
    "prepare": "husky",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "prettier:backend": "cd backend && npm run prettier",
    "prettier:frontend": "cd frontend && npx prettier . --write --config ../config/.prettierrc --ignore-path ../config/.prettierignore",
    "test:e2e": "playwright test --config config/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config config/playwright.config.ts",
    "test:e2e:debug": "playwright test --debug --config config/playwright.config.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.2",
    "@commitlint/config-conventional": "^19.6.2",
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11"
  },
  "dependencies": {
    "eslint": "^9.39.2",
    "prettier": "^3.8.1"
  }
}
